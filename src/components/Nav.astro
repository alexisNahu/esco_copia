---
import {Image} from "astro:assets";
import logo from '../assets/logo-esco.png';
---

<nav class="marg mx-auto flex flex-row items-center justify-between">
    <div class="flex flex-col items-center">
        <a href="/">
            <Image src={logo} alt="ESCO Estudio Contable" class="w-[400px]" />
        </a>
    </div>

    <ul class="flex items-center gap-4 text-sm md:text-[20px] uppercase font-semibold pb-[12px]">
        <li><a href="#nosotros" class="hover:text-lila-esco transition-colors">Nosotros</a></li>
        <li class="border-l border-lila-esco pl-4"><a href="#servicios" class="hover:text-lila-esco transition-colors">Servicios</a></li>
        <li class="border-l border-lila-esco pl-4"><a href="#equipo" class="hover:text-lila-esco transition-colors">Equipo</a></li>
        <li class="border-l border-lila-esco pl-4"><a href="#contacto" class="hover:text-lila-esco transition-colors">Contactos</a></li>
    </ul>
</nav>
