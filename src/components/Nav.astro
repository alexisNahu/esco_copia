---
import { Image } from "astro:assets";
import logo from '../assets/logo-esco.png';
---

<nav class="relative z-50 md:bg-transparent bg-white md:border-b-0 border-b border-gray-100">
    <div class="marg mx-auto flex flex-row items-center justify-between px-6 py-4">
        <div class="flex flex-col items-center">
            <a href="/">
                <Image src={logo} alt="ESCO Estudio Contable" class="w-[100px] md:w-[250px]" />
            </a>
        </div>

        <button
                id="menu-toggle"
                class="relative flex flex-col gap-1.5 z-50 md:hidden ml-auto mr-2 focus:outline-none w-20 h-14 items-center justify-center"
                aria-label="Abrir menú"
        >
            <div class="w-5 h-0.5 bg-lila-esco transition-all duration-300 origin-center line1"></div>
            <div class="w-5 h-0.5 bg-lila-esco transition-all duration-300 line2"></div>
            <div class="w-5 h-0.5 bg-lila-esco transition-all duration-300 origin-center line3"></div>
        </button>

        <ul
                id="menu-items"
                class="hidden md:flex opacity-0 scale-95 md:scale-100 md:opacity-100 absolute md:static top-full left-0 w-full md:w-auto bg-white md:bg-transparent md:shadow-none shadow-lg flex-col md:flex-row items-center gap-0 md:gap-4 text-sm md:text-[20px] uppercase font-semibold py-4 md:py-0 transition-all duration-300 z-40"
        >
            <li class="w-full text-center md:w-auto border-b md:border-b-0 border-gray-100 md:border-lila-esco md:pl-4">
                <a href="#nosotros" class="mobile-link hover:text-lila-esco transition-colors block py-5 md:py-0">Nosotros</a>
            </li>
            <li class="w-full text-center md:w-auto border-b md:border-b-0 border-gray-100 md:border-l md:border-lila-esco md:pl-4">
                <a href="#servicios" class="mobile-link hover:text-lila-esco transition-colors block py-5 md:py-0">Servicios</a>
            </li>
            <li class="w-full text-center md:w-auto border-b md:border-b-0 border-gray-100 md:border-l md:border-lila-esco md:pl-4">
                <a href="#equipo" class="mobile-link hover:text-lila-esco transition-colors block py-5 md:py-0">Equipo</a>
            </li>
            <li class="w-full text-center md:w-auto md:border-l md:border-lila-esco md:pl-4">
                <a href="#contacto" class="mobile-link hover:text-lila-esco transition-colors block py-5 md:py-0">Contactos</a>
            </li>
        </ul>
    </div>
</nav>

<script>
    const menuToggle = document.getElementById('menu-toggle');
    const menuItems = document.getElementById('menu-items');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    function toggleMenu() {
        if (menuItems.classList.contains('hidden')) {
            menuItems.classList.remove('hidden');
            setTimeout(() => {
                menuItems.classList.remove('opacity-0', 'scale-95');
                menuItems.classList.add('flex');
            }, 10);
        } else {
            menuItems.classList.add('opacity-0', 'scale-95');
            menuItems.addEventListener('transitionend', function handler() {
                menuItems.classList.add('hidden');
                menuItems.classList.remove('flex');
                menuItems.removeEventListener('transitionend', handler);
            });
        }

        // Animación de las líneas para formar la "X"
        const line1 = menuToggle.querySelector('.line1');
        const line2 = menuToggle.querySelector('.line2');
        const line3 = menuToggle.querySelector('.line3');

        line1.classList.toggle('rotate-45');
        line1.classList.toggle('translate-y-2');
        line2.classList.toggle('opacity-0');
        line3.classList.toggle('-rotate-45');
        line3.classList.toggle('-translate-y-2');
    }

    menuToggle.addEventListener('click', toggleMenu);

    mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
            if (window.innerWidth < 768) {
                toggleMenu();
            }
        });
    });
</script>

<style>
    .rotate-45 {
        transform: rotate(45deg);
    }
    .-rotate-45 {
        transform: rotate(-45deg);
    }
    .translate-y-2 {
        transform: translateY(1px);
    }
    .-translate-y-2 {
        transform: translateY(-1px);
    }

    /* Asegurar que el botón tenga espacio suficiente y no se corte */
    #menu-toggle {
        overflow: visible !important;
    }

    #menu-toggle .line1,
    #menu-toggle .line2,
    #menu-toggle .line3 {
        transform-origin: center;
        transition: all 0.3s ease;
    }
</style>
