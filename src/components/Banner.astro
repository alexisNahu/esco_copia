---
import Nav from './Nav.astro';
import banner from '../assets/banner.png';
import {Image} from "astro:assets";
import flecha from '../assets/flecha.png'
---
<header
        class="w-full min-h-screen bg-cover bg-center lg:pr-6 relative flex flex-col"
        style={`background-image: url('${banner.src}');`}
>
    <!-- Nav arriba -->
    <div class="relative z-50 w-full">
        <Nav />
    </div>

    <!-- Contenido abajo -->
    <section class="flex-1 flex items-end pb-10 md:pb-20 mb-20">
        <div class="flex items-center w-full">
            <Image
                    src={flecha}
                    alt="Flecha"
                    class="animate-slideInLeft relative -left-10 hidden md:flex"
            />

            <div class="flex flex-row justify-center md:justify-end w-full px-6 items-center">
                <div class="items-center justify-between gap-8 hidden md:flex">
                    <h2 class="text-3xl md:text-[45px] text-lila-esco uppercase">
                    </h2>
                </div>

                <a
                        href="https://wa.me/595972249373"
                        target="_blank"
                        class="animate-pulseSlow border-2 border-lila-esco h-[60px] px-6 text-lila-esco md:text-[32px] items-center flex text-[25px] rounded-full hover:bg-lila-esco hover:text-white transition-all whitespace-nowrap"
                >
                    Hablemos por <span class="font-bold">WhatsApp</span>
                </a>
            </div>
        </div>
    </section>
</header>
