---
import Layout from '../layouts/Layout.astro';
import Banner from "../components/Banner.astro";
import Nav from "../components/Nav.astro";
import star3 from '../assets/star3.png'
import calculadora from '../assets/calculadora.png'
import flecha from '../assets/flecha.png'

import check from '../assets/check.png'
import {Image} from "astro:assets";
import se from '../assets/servicios_estrella.png'
import logo from '../assets/logo_blanco.png';
import estrellita from '../assets/estrellita.png';
import profesional from '../assets/transformamos.png'
import star1 from '../assets/star.png'
import elipse1 from '../assets/ellipse1.png'
import elipse2 from '../assets/ellipse2.png'
import mapaGps from '../assets/gps.png'
import arco from '../assets/ellipse3.png'
import star2 from '../assets/Star 2.png'
import viviana from '../assets/socia.png'
import contabilidad_y_cumplimiento from '../assets/contabilidad.png'
import asesoria_en_sociedades from '../assets/asesoria.png'
import aseesoria_tributaria from '../assets/tributaria.png'
import capacitacion from '../assets/capacitacion.png'
import fotoSocio from '../assets/salvador_maldonado.png'
import mercado_de_valores from '../assets/valores.png'

const servicios = [
	{
		titulo: "Contabilidad & Cumplimiento",
		icono: contabilidad_y_cumplimiento,
		items: ["Registración contable y estados financieros.", "Análisis de Estados Contables.", "Gestión de IVA, IRP y otros impuestos.", "Regularización contable y fiscal."]
	},
	{
		titulo: "Asesoría en Sociedades",
		icono: asesoria_en_sociedades,
		items: ["Gobierno Corporativo.", "Constitución de Sociedades.", "Fusiones y transformaciones.", "Asesoría a Directorio."]
	},
	{
		titulo: "Asesoría Tributaria",
		icono: aseesoria_tributaria,
		items: ["Planificación fiscal.", "Optimización de cargas tributarias.", "Asistencia ante fiscalizaciones.", "Interpretación de normativa vigente."]
	},
	{
		titulo: "Capacitación",
		icono: capacitacion,
		items: ["Contabilidad para no Contadores.", "Finanzas Personales.", "Leasing financiero y Leaseback en Paraguay.", "Negocios Fiduciarios.", "Gobierno Corporativo."]
	},
	{
		titulo: "Mercado de Valores",
		icono: mercado_de_valores,
		items: ["Asesoramiento en inversiones bursátiles.", "Registro y Control de Inversiones."]
	}
];
---

<Layout>
	<Banner/>





	<section class="py-6 bg-lila-esco px-6 animate-fadeInUp" id="nosotros">
		<div class="max-w-[1170px] text-justify mx-auto md:text-[24px]">
			<p class="text-white text-lg md:text-[24px] leading-relaxed">
				<strong class="font-bold">ESCO - Estudio Contable S.R.L.</strong> nace a partir de la sólida trayectoria profesional de sus fundadores, quienes han desarrollado durante años una destacada labor en el asesoramiento contable, tributario y financiero a empresas de diversos sectores económicos.
				<strong class="font-bold">Su creación responde a la necesidad de ofrecer a personas, emprendedores y empresarios un acompañamiento técnico confiable, ético y orientado a resultados, sustentado en la experiencia acumulada de sus socios.</strong>
			</p>
		</div>
	</section>
	<section class="relative w-full flex items-center md:h-[1100px] h-[1040px] overflow-hidden min-w-[1486px]">
		<div class="absolute lg:left-20 md:-top-[350px] -top-[350px] h-full z-0 block w-full md:w-auto animate-fadeIn">
			<Image
				src={profesional}
				alt="Profesional contable"
				class="h-[900px] lg:h-full w-auto object-contain md:object-center"
			/>
		</div>

		<div class="marg mx-auto relative z-10 w-full px-10 lg:left-39 lg:-top-[250px] -top-[290px]">
			<div class="animate-slideInRight">
				<h1
					class="
    uppercase
    leading-tight
    text-lila-esco
    relative
    text-[35px]
    xs:text-[50px]
    tablet:text-[70px]
    laptop:text-[72px]
    desktop:text-[72px]
  "
				>
					<span class="italic font-bold border-b-1">Transformamos</span> <br />
					<span class="italic border-b-1">Números en</span> <br />
					<span class="italic font-bold">Decisiones</span> <br />
					que <span class="italic font-bold">Hacen</span> <br />

					<span class="border-2 md:border-4 border-lila-esco pl-4 lg:pl-6 pr-6 lg:pr-11 py-1 lg:py-2 rounded-full inline-flex items-center justify-start leading-none mt-2">
<span
	class="
    italic
    font-bold
   text-[34px]
    xs:text-[50px]
    tablet:text-[70px]
    laptop:text-[72px]
    desktop:text-[72px]
  "
>
  Crecer
</span>
       </span>
				</h1>
			</div>
		</div>

		<Image
			src={star1}
			alt="star1"
			class="animate-float absolute hidden lg:flex bottom-50 -left-[100px] w-16 md:w-80"
		/>

		<Image
			src={star2}
			alt="star1"
			class="animate-float absolute right-0 bottom-[630px] md:bottom-[850px] w-24 md:w-36"
		/>
	</section>



	<section class="py-20 px-6 bg-white lg:-mt-72 -mt-[500px]">
		<div class="max-w-[1200px] text-lila-esco mx-auto w-full justify-items-center grid grid-cols-1 md:text-[20px] md:grid-cols-2 gap-16">
			<div class="animate-fadeInLeft flex flex-col gap-4">
				<h2 class="text-4xl font-semibold md:text-[60px] uppercase tracking-wide">Misión</h2>
				<p class="max-w-[500px]">Apoyar a las personas, emprendedores y empresas en su búsqueda de diferenciación competitiva, brindando servicios e información oportuna y de calidad para la toma de decisiones.</p>
			</div>
			<div class="animate-fadeInRight flex flex-col gap-4">
				<h2 class="text-4xl font-bold uppercase md:text-[60px] tracking-wide">Visión</h2>
				<p class="max-w-[500px]">Ser una empresa modelo de prestación de servicios, reconocida por la calidad, agilidad y eficiencia, contribuyendo con valor agregado mediante el uso eficaz del conocimiento administrativo y la tecnología.</p>
			</div>
		</div>
	</section>
	<section class="relative w-full bg-white mt-[100px]">
		<Image
			src={elipse1}
			alt="star1"
			class="animate-pulseSlow absolute left-0 bottom-1 w-16 md:w-96 opacity-50 md:opacity-100"
		/>
		<Image
			src={elipse2}
			alt="star1"
			class="animate-pulseSlow absolute right-0 -top-56 w-16 md:w-96 opacity-50 md:opacity-100"
		/>
		<div class="relative flex flex-col min-w-[100%]">

			<div class="absolute top-10 w-full z-0">
				<Image src={arco} alt="Arco de valores" class="w-full h-auto object-contain" />
			</div>

			<div class="relative md:w-[400px] mx-auto min-[1511px]:hidden flex flex-col items-start text-left gap-3 mt-28 mb-8 z-10 px-6 justify-center">

  <span class="animate-fadeInUp w-[300px] mx-auto md:w-full stagger-1 border-2 text-center border-lila-esco text-lila-esco px-6 py-2 rounded-full bg-white font-bold text-sm">
    COMPROMISO
  </span>

				<span class="animate-fadeInUp w-[300px] mx-auto  min-w-[100px] stagger-2 md:w-full border-2 text-center  border-lila-esco text-lila-esco px-6 py-2 rounded-full bg-white font-bold text-sm">
    CONFIDENCIALIDAD
  </span>

				<span class="animate-fadeInUp w-[300px] stagger-3 mx-auto  min-w-[100px] md:w-full border-2 border-lila-esco text-center  text-lila-esco px-6 py-2 rounded-full bg-white font-bold text-sm">
    LEALTAD
  </span>

				<span class="animate-fadeInUp w-[300px] stagger-4 md:w-full mx-auto  border-2 border-lila-esco text-lila-esco text-center  px-6 py-2 rounded-full bg-white font-bold text-sm">
    HONESTIDAD
  </span>

				<span class="animate-fadeInUp w-[300px] stagger-5 md:w-full border-2 mx-auto  border-lila-esco text-lila-esco px-6 py-2 rounded-full text-center  bg-white font-bold text-sm">
    DEDICACIÓN
  </span>

				<span class="animate-fadeInUp stagger-6 md:w-full w-[300px] border-2 mx-auto  border-lila-esco text-lila-esco px-6 py-2 rounded-full bg-white font-bold text-center  text-sm">
    TRABAJO EN EQUIPO
  </span>

			</div>

			<div class="relative w-full h-[300px] mt-28 z-10 text-[24px] font-medium hidden min-[1510px]:block">
				<span class="animate-zoomIn stagger-1 absolute top-[190px] left-[11%] border-2 border-lila-esco text-lila-esco px-6 py-2 rounded-full bg-white font-bold transition-transform hover:scale-105">COMPROMISO</span>
				<span class="animate-zoomIn stagger-2 absolute top-[80px] left-[18%] border-2 border-lila-esco text-lila-esco px-6 py-2 rounded-full bg-white font-bold transition-transform hover:scale-105">CONFIDENCIALIDAD</span>
				<span class="animate-zoomIn stagger-3 absolute top-[5px] left-[36%] border-2 border-lila-esco text-lila-esco px-6 py-2 rounded-full bg-white font-bold transition-transform hover:scale-105">LEALTAD</span>
				<span class="animate-zoomIn stagger-4 absolute top-[5px] right-[36%] border-2 border-lila-esco text-lila-esco px-6 py-2 rounded-full bg-white font-bold transition-transform hover:scale-105">HONESTIDAD</span>
				<span class="animate-zoomIn stagger-5 absolute top-[80px] right-[22%] border-2 border-lila-esco text-lila-esco px-6 py-2 rounded-full bg-white font-bold transition-transform hover:scale-105">DEDICACIÓN</span>
				<span class="animate-zoomIn stagger-6 absolute top-[190px] right-[10%] border-2 border-lila-esco text-lila-esco px-6 py-2 rounded-full bg-white font-bold transition-transform hover:scale-105">TRABAJO EN EQUIPO</span>
			</div>

			<div class="absolute top-11 right-[350px] z-50 w-96 h-96 hidden desktop:block">
				<Image
					src={estrellita}
					alt="Arco de valores"
					class="animate-spinSlow absolute top-0 right-0 w-32 h-32"
				/>
			</div>
			<h2 class="text-[35px] md:text-[60px] font-semibold text-lila-esco uppercase text-center mb-16 z-20 -mt-[500px] min-[1510px]:-mt-[200px] leading-[50px] md:leading-[60px]">Nuestros <br class="hidden md:block"/> Valores
			</h2>
		</div>
	</section>

	<section class="py-11 bg-lila-esco w-full overflow-hidden mt-[480px] min-[1510px]:mt-16" id="servicios">
		<div class="marg mx-auto px-6">
			<h2 class="animate-fadeInUp text-5xl font-extrabold text-white uppercase text-center mb-16 tracking-wide">
				Servicios
			</h2>
			<div class="flex flex-wrap justify-items-center justify-center -mx-2]">
				{servicios.map((servicio, index) => (

					<div class={`animate-fadeInUp stagger-${index + 1} border-2 max-h-[700px] md:min-h-[350px]  border-white/20 rounded-3xl py-[12px] px-[30px] hover:bg-white/5 transition-all w-full  max-w-[520px] mx-2 mb-16 relative`}>



						<div class="absolute -top-8 left-6 border-2 border-white/20 rounded-full px-6 py-3 bg-lila-esco">

							<Image

								src={servicio.icono}

								alt={servicio.titulo}

								class="w-16 h-16 object-contain"

							/>

						</div>



						<div class="mt-16 md:mt-10 flex flex-col">

							<h3 class="text-2xl md:text-[24px] font-black text-white uppercase mb-4 leading-tight h-[70px] text-center max-w-[250px] mx-auto">

								{servicio.titulo}

							</h3>



							<ul class="space-y-3">

								{servicio.items.map((item) => (

									<li class="text-white/80 flex text-[20px] items-center gap-2">

										<Image src={se} alt="estrellita servicio" class="w-3 h-3 m-0" /> {item}

									</li>

								))}

							</ul>

						</div>

					</div>

				))}
			</div>
		</div>
	</section>

	<section class="relative h-auto bg-cover py-11 bg-center bg-no-repeat w-full overflow-hidden bg-[url('../assets/calculadora.png')] bg-cover bg-center">
		<div class="absolute inset-0 bg-white/70 md:bg-transparent"></div>

		<div class="md:max-w-[1550px] mx-auto flex flex-col md:flex-row gap-6 md:gap-20 items-center lg:justify-center justify-between min-h-[410px] relative z-10 font-bold py-10 md:py-0 px-4 md:px-6">
			<h2 class="animate-slideInLeft text-3xl md:text-6xl italic text-lila-esco uppercase leading-tight font-bold text-center md:text-left">
				¿Por qué <br /> <strong>elegirnos?</strong>
			</h2>

			<div class="flex flex-col w-full gap-2 md:gap-3 text-sm md:text-[24px]">
				<p class="animate-fadeInRight stagger-1 font-medium uppercase text-center md:text-left"><strong>ATENCIÓN</strong> PERSONALIZADA Y CERCANA</p>
				<p class="animate-fadeInRight stagger-2 font-medium uppercase text-center md:text-left"><strong>INFORMACIÓN</strong> CLARA PARA DECIDIR</p>
				<p class="animate-fadeInRight stagger-3 font-medium uppercase text-center md:text-left"><strong>ENFOQUE</strong> PREVENTIVO Y ESTRATÉGICO</p>
				<p class="animate-fadeInRight stagger-4 font-medium uppercase text-center md:text-left"><strong>CUMPLIMIENTO</strong> OPORTUNO DE OBLIGACIONES</p>
				<p class="animate-fadeInRight stagger-5 font-medium uppercase text-center md:text-left"><strong>HONORARIOS</strong> COMPETITIVOS Y TRANSPARENTES</p>
			</div>

			<div class="hidden lg:block">
				<Image src={check} alt="check" class="animate-bounceSlow w-80 relative -left-[270px] -top-[80px]"/>
			</div>
		</div>
	</section>
	<!-- Sección 1 - Socio Fundador (SIN ANIMACIONES) -->
	<section class="relative bg-white lg:max-h-screen" id="equipo">
		<div class="w-full flex flex-col lg:flex-row items-center relative lg:h-screen">

			<div class="relative w-full lg:w-[50%] lg:h-full">
				<div class="relative w-full aspect-[4/5] lg:aspect-auto h-full overflow-hidden shadow-2xl border-gray-100">
					<Image src={fotoSocio} alt="Salvador R. Maldonado Díaz" class="absolute inset-0 w-full h-full object-cover object-top lg:object-center" />

					<div class="absolute top-4 md:top-40 left-4 md:left-26 z-10">
						<p class="text-white font-bold md:mt-0 mt-19 text-3xl md:text-[36px] uppercase italic leading-tight">
							Lic. <br /> Salvador R. <br /> Maldonado <br/> Díaz
						</p>
					</div>

					<div class="absolute bottom-0 w-full py-1 text-center h-[10%] lg:h-[5%] z-10 flex justify-center items-center">
						<p class="text-white uppercase text-2xl md:text-[40px] lg:text-[30px] ">Socio Fundador</p>
					</div>
				</div>
			</div>

			<div class="hidden lg:block absolute left-[51%] top-[100px] -translate-x-1/2 -translate-y-1/2 z-10">
				<Image src={flecha} alt="flecha" class="w-24 lg:w-[210px] h-auto" />
			</div>

			<div class="w-full lg:w-[50%] flex flex-colgap-4 md:gap-6 px-4 pb-8 text-sm  lg:max-w-[650px] md:text-[20px] text-lila-esco text-justify mx-auto mt-6 lg:mt-0 lg:overflow-y-auto lg:max-h-screen">
				<Image
					src={star3}
					alt="star1"
					class="absolute right-0 -top-44 w-16 md:w-64 opacity-30 md:opacity-100 animate-spinSlow animate-float"
				/>

				<p class="px-2 md:px-0">
					Profesional contable con más de tres décadas de experiencia en gestión corporativa de primer nivel en Paraguay. Licenciado en Ciencias Contables por la Universidad Católica de Asunción, con formación de posgrado en Contabilidad y Finanzas, incluyendo un Executive MBA en la Universidad Alfonso X El Sabio (España). Durante 33 años lideró el Departamento Contable, la Gerencia Administrativa y la Gerencia General de la Unidad de Servicios Compartidos del Grupo Rieder & Cía., uno de los grupos empresariales más importantes del país, en los sectores automotriz y de infraestructura eléctrica. Actualmente ejerce como Socio Fundador de ESCO Estudio Contable S.R.L., brindando asesoramiento contable, tributario, financiero y societario a empresas, emprendedores y personas. A lo largo de su carrera se ha desempeñado como Síndico en diversas empresas nacionales, garantizando transparencia y control interno. Es socio activo del Colegio de Contadores del Paraguay. Su visión combina rigor técnico, experiencia corporativa y compromiso con el crecimiento de sus clientes.
				</p>
			</div>

		</div>
	</section>

	<!-- Sección 2 - Socia (SIN ANIMACIONES) -->
	<section class="relative bg-white lg:max-h-screen">
		<div class="w-full flex flex-col lg:flex-row items-center relative">

			<div class="w-full lg:w-[50%] flex flex-col gap-4 md:gap-6 text-sm md:text-[20px] lg:max-w-[600px] pb-8 md:pb-[100px] text-lila-esco text-justify mx-auto px-4 md:px-0 mt-6 lg:mt-0 order-2 lg:order-1">
				<Image
					src={elipse1}
					alt="star1"
					class="absolute left-[0px] top-[500px] w-16 md:w-52 z-50 opacity-30 md:opacity-100"
				/>
				<Image
					src={elipse1}
					alt="star1"
					class="absolute left-[0px] top-[200px] w-16 md:w-52 z-50 opacity-30 md:opacity-100"
				/>
				<Image
					src={star3}
					alt="star1"
					class="absolute left-[0px] rotate-180 top-[800px] w-16 md:w-52 z-50 pl-11 opacity-30 animate-spinSlow animate-float md:opacity-100"
				/>
				<p class="px-2">
					Contadora Pública Nacional egresada de la Universidad Nacional de Asunción, con sólida formación en tributación, costos, presupuestos, auditoría, cumplimiento SEPRELAD y liderazgo empresarial. Integra el equipo fundador de ESCO Estudio Contable S.R.L., donde lidera los servicios de contabilidad, liquidación de impuestos y asesoría a empresas y personas en Paraguay. Especializada en el cumplimiento de obligaciones ante la SET, manejo del régimen de IVA, IRE, IRP y normativa tributaria vigente. Su enfoque práctico y orientado al cliente garantiza información clara y oportuna para la toma de decisiones. Combina conocimiento técnico actualizado con una atención personalizada que distingue a ESCO en el mercado. Comprometida con la excelencia profesional y el acompañamiento cercano a cada cliente en todas las etapas de su negocio.
				</p>
			</div>

			<div class="hidden lg:block absolute left-[49%] top-[100px] -translate-x-1/2 -translate-y-1/2 z-10">
				<Image src={flecha} alt="flecha" class="w-24 lg:w-[206px] h-auto rotate-180" />
			</div>

			<div class="relative w-full lg:w-[50%] order-1 lg:order-2">
				<div class="relative w-full aspect-[4/5] lg:aspect-auto lg:h-screen overflow-hidden shadow-2xl border-gray-100">
					<Image src={viviana} alt="Viviana R. Maldonado López" class="absolute inset-0 w-full h-full object-cover object-top lg:object-center" />

					<div class="absolute top-4 md:top-40 left-4 md:left-26 z-10">
						<p class="text-white font-bold md:mt-0 mt-19 text-3xl md:text-[36px] uppercase italic leading-tight">
							C.P. <br /> Viviana R. <br /> Maldonado <br/> López
						</p>
					</div>


					<div class="absolute bottom-0 w-full py-1 text-center h-[10%] lg:h-[5%] z-10 flex justify-center items-center">
						<p class="text-white uppercase text-2xl md:text-[40px] lg:text-[30px] ">Socia</p>
					</div>
				</div>
			</div>

		</div>
	</section>


	<section class="mx-auto py-12 md:py-24 lg:max-w-[90%] bg-white px-4 md:px-6" id="contacto">
		<div class="flex flex-col justify-between lg:flex-row gap-8 md:gap-16 items-center">

			<div class="animate-fadeInLeft lg:max-w-[443px]">
				<h2 class="text-2xl md:text-4xl italic font-bold text-lila-esco mb-4 uppercase text-center md:text-left">OPTIMIZÁ TUS IMPUESTOS <strong>HOY</strong></h2>
				<p class="text-lila-esco mb-6 md:mb-8 text-base md:text-[20px] text-center md:text-left">Queremos ser aliados estratégicos en el crecimiento y control financiero de tu empresa.</p>
				<form action="https://api.web3forms.com/submit" method="POST" class="mx-auto lg:max-w-[100%] justify-center flex flex-col gap-4">
					<input type="hidden" name="title" value="Notificación: Nuevo formulario de contacto recibido - ESCO Estudio Contable" />					<input type="hidden" name="access_key" value="7d1fdf7a-5971-4335-866e-23e7c9592352" />
					<input type="hidden" name="subject" value="Nuevo contacto desde la Web - ESCO" />
					<input type="hidden" name="from_name" value="Web ESCO Estudio Contable" />

					<input type="hidden" name="language" value="es" />

					<input
						type="text"
						name="nombre_apellido"
						required
						placeholder="Nombre y Apellido"
						class="w-full px-4 rounded-full h-[40px] border-2 border-lila-esco focus:outline-none transition-all placeholder:text-lila-esco placeholder:text-sm"
					/>

					<div class="flex flex-col sm:flex-row gap-4">
						<input
							type="tel"
							name="telefono"
							required
							pattern="[0-9]{6,15}"
							title="Por favor, ingresa un número de teléfono válido (solo números, entre 6 y 15 dígitos)"
							placeholder="Tel: (ej. 0981123456)"
							class="w-full sm:w-1/2 px-4 h-[40px] text-lila-esco rounded-full border-2 border-lila-esco focus:outline-none transition-all placeholder:text-lila-esco placeholder:text-sm"
						/>
						<input
							type="email"
							name="email"
							required
							placeholder="Email"
							class="w-full sm:w-1/2 px-4 h-[40px] rounded-full border-2 border-lila-esco focus:outline-none transition-all placeholder:text-lila-esco placeholder:text-sm"
						/>
					</div>

					<textarea
						name="mensaje"
						required
						placeholder="Mensaje"
						rows="4"
						class="w-full p-4 rounded-3xl border-2 border-lila-esco focus:outline-none transition-all placeholder:text-lila-esco placeholder:text-sm"
					></textarea>

					<button type="submit" class="bg-lila-esco h-[40px] text-white px-6 md:px-10 rounded-full hover:bg-opacity-90 transition-all w-max text-sm md:text-[20px] shadow-lg leading-none inline-flex items-center justify-center mx-auto md:mx-0">
						Enviar
					</button>
				</form>
			</div>

